# ===========================================
# Aluminify - Variáveis de Ambiente
# ===========================================

# -------------------------------------------
# Core
# -------------------------------------------
NODE_ENV=development

# -------------------------------------------
# Supabase (Obrigatório)
# -------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=your-publishable-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-secret-key

# -------------------------------------------
# Auth / OAuth (Required)
# -------------------------------------------
# Chave de criptografia para client_secret dos tenants (min 32 chars)
OAUTH_ENCRYPTION_KEY=your-encryption-key-here-min-32-chars

# -------------------------------------------
# Google Analytics (Opcional)
# -------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# -------------------------------------------
# Sentry (Opcional - Build/Runtime)
# -------------------------------------------
SENTRY_AUTH_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TUNNEL_ROUTE=false

# -------------------------------------------
# Stripe (Opcional - Pagamentos Recorrentes)
# -------------------------------------------
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# -------------------------------------------
# SMTP (Opcional - fora da Cloudron)
# -------------------------------------------
# Em Cloudron, prefira o addon sendmail. As variáveis CLOUDRON_MAIL_* são
# injetadas automaticamente e não precisam ser definidas manualmente.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_IGNORE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=

# -------------------------------------------
# Build & CI (Opcional)
# -------------------------------------------
DOCKER_BUILD=false
CI=false
