# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_OR_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SECRET_KEY=sb_secret_xxx


# Next.js Configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: SMTP (non-Cloudron environments)
# On Cloudron, use the sendmail addon instead of these variables.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_IGNORE_TLS=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=no-reply@example.com
# SMTP_FROM_NAME=Aluminify

# Stripe (Pagamentos Recorrentes)
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Logging
LOG_LEVEL=info
